# ==========================================================
# GHEVERHAN Commerce Platform
# EditorConfig
# ==========================================================

root = true

# ==========================================================
# Default
# ==========================================================

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ==========================================================
# Markdown
# ==========================================================

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ==========================================================
# JSON
# ==========================================================

[*.{json,jsonc}]
indent_size = 2

# ==========================================================
# YAML
# ==========================================================

[*.{yml,yaml}]
indent_size = 2

# ==========================================================
# JavaScript
# ==========================================================

[*.{js,mjs,cjs}]
indent_size = 2

# ==========================================================
# TypeScript
# ==========================================================

[*.{ts,tsx}]
indent_size = 2

# ==========================================================
# React
# ==========================================================

[*.jsx]
indent_size = 2

# ==========================================================
# CSS
# ==========================================================

[*.{css,scss,sass}]
indent_size = 2

# ==========================================================
# HTML
# ==========================================================

[*.html]
indent_size = 2

# ==========================================================
# PHP
# ==========================================================

[*.php]
indent_size = 4

# ==========================================================
# Blade
# ==========================================================

[*.blade.php]
indent_size = 4

# ==========================================================
# Shell
# ==========================================================

[*.sh]
indent_size = 2

# ==========================================================
# Docker
# ==========================================================

[Dockerfile]
indent_size = 2

# ==========================================================
# GitHub Actions
# ==========================================================

[.github/**/*.yml]
indent_size = 2